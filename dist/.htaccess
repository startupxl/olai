# Olai Notes — Hostinger .htaccess
# Routes all requests through Node.js / index.html for the SPA

Options -MultiViews
RewriteEngine On

# If the request is for a real file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise send to index.html (SPA routing)
RewriteRule ^ index.html [L]
