# Copy this file to .env and fill in the values.
# This file IS committed to the repo — never put real secrets in it.

# Firebase (already set in firebase.js fallbacks — only needed to override)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google AdSense — https://www.google.com/adsense
VITE_ADSENSE_CLIENT=ca-pub-2370042398000168
VITE_ADSENSE_SLOT_NL=     # Ad slot ID for the note-list banner
VITE_ADSENSE_SLOT_SB=     # Ad slot ID for the sidebar banner

# PayPal Subscriptions (client-side, Vite build)
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_PLAN_ID_MONTHLY=   # P-... monthly plan
VITE_PAYPAL_PLAN_ID_ANNUAL=    # P-... annual plan

# PayPal Webhooks (server-side, not exposed to browser)
# PAYPAL_CLIENT_ID and PAYPAL_CLIENT_SECRET = same values as above without VITE_ prefix
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID: after deploying, register webhook in PayPal dashboard:
#   URL: https://olainotes.com/api/webhooks/paypal
#   Events: BILLING.SUBSCRIPTION.CANCELLED, BILLING.SUBSCRIPTION.EXPIRED,
#           BILLING.SUBSCRIPTION.SUSPENDED, BILLING.SUBSCRIPTION.ACTIVATED,
#           BILLING.SUBSCRIPTION.RE-ACTIVATED, BILLING.SUBSCRIPTION.PAYMENT.FAILED
#   Then paste the Webhook ID shown in the dashboard here:
PAYPAL_WEBHOOK_ID=

# Firebase Admin SDK (OPTIONAL — server-side webhook Firestore writes)
# If not set, webhook events are received and verified but Firestore is not updated server-side.
# Plans still activate via the client-side updatePlan() call on PayPal approval.
# Cancellations still expire naturally at planExpiresAt (set at subscription time).
# To enable: generate a service account key and paste the entire JSON as a single-line string.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"olai-dc635",...}
