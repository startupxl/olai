# Copy this file to .env and fill in the values.
# This file IS committed to the repo — never put real secrets in it.

# Firebase (already set in firebase.js fallbacks — only needed to override)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google AdSense — https://www.google.com/adsense
VITE_ADSENSE_CLIENT=ca-pub-2370042398000168
VITE_ADSENSE_SLOT_NL=     # Ad slot ID for the note-list banner
VITE_ADSENSE_SLOT_SB=     # Ad slot ID for the sidebar banner

# PayPal Subscriptions — https://developer.paypal.com
# 1. Create a REST app → copy Live Client ID
# 2. Subscriptions → Plans → Create Plan ($7.99/mo) → copy Plan ID (P-...)
VITE_PAYPAL_CLIENT_ID=
VITE_PAYPAL_PLAN_ID=
